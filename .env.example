# ============================================
# World Monitor Fish - Environment Variables
# ============================================
# Copy this file to .env and fill in values

# === Shared ===
REDIS_TOKEN=                          # Required: strong random token for Redis auth
INTEGRATION_API_KEYS=                 # Comma-separated API keys for cross-service auth

# === WorldMonitor ===
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=${REDIS_TOKEN}
FINNHUB_API_KEY=
ACLED_EMAIL=
ACLED_ACCESS_TOKEN=
NASA_FIRMS_API_KEY=
AISSTREAM_API_KEY=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
RELAY_SHARED_SECRET=
TURNSTILE_SECRET_KEY=
VITE_SENTRY_DSN=
VITE_VARIANT=full

# === MiroFish ===
SECRET_KEY=                           # Required: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
ZEP_API_KEY=
MIROFISH_API_KEYS=${INTEGRATION_API_KEYS}
MIROFISH_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
MIROFISH_AUTH_DISABLED=false          # Set to true ONLY for local dev without auth

# === Integration Service ===
INTEGRATION_PORT=4000
WM_API_URL=http://localhost:3000
MF_API_URL=http://localhost:5001
